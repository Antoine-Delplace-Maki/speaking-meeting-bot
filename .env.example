###
### CORE - required
###

# MeetingBaas API Key - meeting bot connectivity (Zoom, Google Meet, Teams)
MEETING_BAAS_API_KEY=your_meetingbaas_api_key_here

# OpenAI API Key - LLM, avatar generation (gpt-image-1), voice matching
OPENAI_API_KEY=your_openai_api_key_here

# Deepgram API Key - speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cartesia API Key - text-to-speech
CARTESIA_API_KEY=your_cartesia_api_key_here

# Default Cartesia voice ID (used as fallback when no voice is matched)
CARTESIA_VOICE_ID="79a125e8-cd45-4c13-8a67-188112f4dd22"

# Server port
PORT=7014

###
### PRODUCTION - set for deployed servers
###

# Public base URL for WebSocket connections (e.g. https://your-server.com)
BASE_URL=

###
### LOCAL DEVELOPMENT - optional
###

# Ngrok auth token (for local dev tunneling)
NGROK_AUTHTOKEN=
